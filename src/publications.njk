---
layout: layouts/base.njk
title: All publications
pagination:
  data: collections.publications
  size: 6
  alias: paginatedPublications
permalink: "publications/{% if pagination.pageNumber > 0 %}page/{{ pagination.pageNumber + 1 }}/{% endif %}"
---

<section class="relative px-10 py-12 overflow-hidden">

	<!-- Header -->
	<p class="text-center text-xs uppercase tracking-widest text-gray-400 mb-2">Publications</p>
	<h1 class="text-center text-3xl md:text-5xl font-bold leading-tight mb-4">All publications</h1>
	<p class="text-center text-base text-gray-500 max-w-lg mx-auto mb-10">
		A complete archive of our work. From early-stage explorations to shipped tools.
		Each project reflects our commitment to clarity, craft, and long-term thinking.
	</p>

	<!-- Container -->
	<div class="flex flex-wrap justify-center gap-5 max-w-4xl mx-auto pb-5">
		{% for entry in collections.publications | limit(5) %}
			<a href="{{ entry.data.href }}" target="_blank" rel="noopener noreferrer">
				<div class="flex flex-col items-start space-y-2 w-64 min-h-64 bg-white border border-gray-200 rounded-xl p-6 transition-all duration-300 hover:-translate-y-1 hover:border-gray-300 hover:bg-gray-100">
					<!-- Category Name -->
					{% if entry.data.tag %}
						<span class="self-start text-xs font-medium px-2 py-0.5 rounded-full bg-blue-100 border border-blue-400 text-blue-700">
							{{ entry.data.tag }}
						</span>
					{% endif %}

					<!-- Entry Name -->
					<p class="w-full text-base font-semibold tracking-tight text-gray-900">
						{{ entry.data.name }}
					</p>

					<!-- Entry Description -->
					<p class="w-full text-sm font-normal text-gray-500 leading-relaxed">
						{{ entry.data.desc }}
					</p>

					<!-- Release date -->
					{% if entry.data.date %}
						<div class="flex items-center gap-1.5 mt-auto pt-2">
							<span class="text-xs text-gray-400">{{ entry.data.date | simplifyDate }}</span>
						</div>
					{% endif %}
				</div>
			</a>
		{% endfor %}
	</div>
</section>


<!-- Pagination nav -->
<nav class="flex items-center justify-center gap-6 max-w-4xl mx-auto mt-8 pt-6 border-t border-gray-200">

  {% if pagination.href.previous %}
    <a href="{{ pagination.href.previous }}" class="text-sm text-gray-600 border border-gray-300 rounded-lg px-4 py-2 hover:bg-gray-100 transition-colors"><i class="fa-solid fa-angle-left"></i> Prev</a>
  {% else %}
    <span class="text-sm text-gray-300 border border-gray-200 rounded-lg px-4 py-2 cursor-not-allowed"><i class="fa-solid fa-angle-left"></i> Prev</span>
  {% endif %}

  <span class="text-xs text-gray-400">{{ pagination.pageNumber + 1 }} / {{ pagination.pages.length }}</span>

  {% if pagination.href.next %}
    <a href="{{ pagination.href.next }}" class="text-sm text-gray-600 border border-gray-300 rounded-lg px-4 py-2 hover:bg-gray-100 transition-colors">Next <i class="fa-solid fa-angle-right"></i></a>
  {% else %}
    <span class="text-sm text-gray-300 border border-gray-200 rounded-lg px-4 py-2 cursor-not-allowed">Next <i class="fa-solid fa-angle-right"></i></span>
  {% endif %}

</nav>