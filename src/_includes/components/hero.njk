<section class="relative flex justify-center min-h-80 px-4 sm:px-10 py-12 overflow-hidden" id="hero">
	<div class="flex flex-col md:flex-row gap-8 items-center">

		<!-- Text -->
		<div class="relative z-10 flex flex-col items-center text-center md:items-start md:text-left max-w-sm">

			<p class="text-sm font-medium tracking-widest uppercase text-gray-400 mb-4">Welcome</p>
			<h1 class="text-3xl md:text-5xl font-bold leading-tight mb-5">{{ hero.title }}</h1>

			<!-- Description -->
			<p class="text-base leading-relaxed text-gray-500 mb-7">
				{{hero.desc}}
			</p>

			<!-- CTA Buton -->
			<a href="{{ hero.button_link }}" class="inline-flex items-center gap-2 text-sm font-medium border border-gray-300 rounded-full px-6 py-2.5 hover:bg-gray-100 transition-colors">
				{{hero.button_label}}
			</a>
		</div>

		<!-- Image -->
		<div class="relative z-10 flex justify-center items-center">
		<div class="w-48 h-48 md:w-64 md:h-64 rounded-3xl border border-gray-200 overflow-hidden rotate-6 hover:-rotate-1 hover:scale-105 transition-transform duration-300">
			<img src="{{ hero.img }}" alt="Our Logo" class="w-full h-full object-cover" />
		</div>
		</div>

	</div>
</section>