<section class="relative px-4 sm:px-10 py-12 overflow-hidden" id="credibility">
 
	<!-- Subtle top divider -->
	<div class="max-w-4xl mx-auto mb-12">
		<div class="h-px bg-gray-200 w-full"></div>
	</div>
 
	<!-- Header -->
	<p class="text-center text-xs uppercase tracking-widest text-gray-400 mb-2">Credibility</p>
	<p class="text-center text-3xl md:text-5xl font-bold leading-tight mb-2">By the numbers</p>
	<p class="text-center text-base text-gray-500 mb-10">A snapshot of our research output and reach</p>
 
	<!-- Stats grid -->
	<div class="flex flex-wrap justify-center gap-5 max-w-2xl mx-auto pb-5">
		{% for stat in credibility.stats %}
			<div class="bg-white border border-gray-200 rounded-xl p-6 flex flex-col items-center text-center w-32">
					<span class="text-4xl font-bold text-gray-900 tabular-nums"	data-count="{%- if stat.collection -%} {{ collections[stat.collection] | length }} {%- elseif stat.data -%}{{ getDataLength(stat.data) }} {%- else -%}{{ stat.manual }} {%- endif -%}">0</span>
					<span class="text-xs uppercase tracking-widest text-gray-400 mt-2">{{ stat.label }}</span>
			</div>
		{% endfor %}
	</div>
 
	<!-- Venue highlights -->
	{% if credibility.venues | length > 0 %}
		<div class="max-w-4xl mx-auto">
			<div class="flex items-center gap-4 mb-5">
					<p class="text-xs uppercase tracking-widest text-gray-400 shrink-0">Featured venues</p>
					<div class="h-px bg-gray-200 flex-1"></div>
			</div>
	
			<div class="flex flex-wrap justify-center gap-3">
				{% for entry in credibility.venues %}
					<span class="text-xs font-semibold px-3 py-1.5 rounded-full bg-white border border-gray-200 text-gray-600">{{entry.name}}</span>
				{% endfor %}
			</div>
		</div>
	{% endif %}
 
</section>