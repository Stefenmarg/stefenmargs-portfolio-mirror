<section class="relative px-4 sm:px-10 py-12 overflow-hidden" id="partners">
	<!-- Subtle top divider -->
	<div class="max-w-4xl mx-auto mb-12">
		<div class="h-px bg-gray-200 w-full"></div>
	</div>

	<!-- Header -->
	<p class="text-center text-xs uppercase tracking-widest text-gray-400 mb-2">Collaborations</p>
	<p class="text-center text-3xl md:text-5xl font-bold leading-tight mb-2">Partners & funders</p>
	<p class="text-center text-base text-gray-500 mb-10">Institutions and organisations we work with</p>

	<!-- Groups -->
	<div class="max-w-4xl mx-auto">
		{% for group in partners.categories %}
			{% if group.items %}
				<div class="mb-10">

					<!-- Group label -->
					<div class="flex items-center gap-4 mb-5">
						<p class="text-xs uppercase tracking-widest text-gray-400 shrink-0">{{ group.label }}</p>
						<div class="h-px bg-gray-200 flex-1"></div>
					</div>

					<!-- Logo / Brand grid -->
					<div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 gap-3">
						{% for partner in group.items %}
						<a href="{{ partner.url or '#' }}" target="_blank" rel="noopener noreferrer" class="group relative flex items-center justify-center bg-white border border-gray-200 rounded-xl overflow-hidden hover:border-gray-300 hover:bg-gray-100 transition-all duration-300 min-h-[80px]">
							{% if partner.logo %}
								<img src="{{ partner.logo }}" alt="{{ partner.title }}"
									class="p-4 w-full h-full object-contain opacity-50 group-hover:opacity-100 transition-opacity duration-200" />
							{% else %}
								<span class="text-sm font-semibold text-gray-500 group-hover:text-gray-900 text-center leading-snug transition-colors duration-200 p-5">{{ partner.title }}</span>
							{% endif %}
						</a>
						{% endfor %}
					</div>

				</div>
			{% endif %}
		{% endfor %}
	</div>
</section>