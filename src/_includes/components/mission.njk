<section class="max-w-2xl mx-auto px-4 sm:px-6 py-12 sm:py-20" id="mission">
    <!-- Subtle top divider -->
    <div class="max-w-4xl mx-auto mb-12">
        <div class="h-px bg-gray-200 w-full"></div>
    </div>
    
    <p class="text-sm uppercase tracking-widest text-gray-400 mb-6">Mission</p>
    <h2 class="text-3xl font-medium leading-snug text-gray-900 mb-6">
        {{ mission.title }}
    </h2>

    <div class="w-10 h-px bg-gray-300 mb-6"></div>

    <p class="text-base leading-relaxed text-gray-500 mb-10 max-w-lg">
        {{ mission.desc }}
    </p>

    <!-- Mission entries grid -->
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
        {% for entry in mission.items %}   
            <div class="border-t border-gray-200 pt-4">
                <p class="text-sm font-medium text-gray-800 mb-1"> {{ entry.title }} </p>
                <p class="text-sm text-gray-400 leading-relaxed"> {{ entry.desc }} </p>
            </div>
        {% endfor %}
    </div>
</section>