<section class="relative px-4 sm:px-10 py-12 overflow-hidden" id="team">
	<!-- Subtle top divider -->
    <div class="max-w-4xl mx-auto mb-12">
        <div class="h-px bg-gray-200 w-full"></div>
    </div>

	<!-- Header -->
	<p class="text-center text-xs uppercase tracking-widest text-gray-400 mb-2">Team</p>
	<p class="text-center text-3xl md:text-5xl font-bold leading-tight mb-2">Our team</p>
	<p class="text-center text-base text-gray-500 mb-10">{{ team.desc }}</p>

	<!-- Container -->
	<div class="flex flex-wrap justify-center gap-5 max-w-4xl mx-auto">
		{% for entry in team.items %}
		  	<!-- Individual entry -->
			<div class="flex flex-col items-center space-y-2 w-64 min-h-64 bg-white border border-gray-200 rounded-xl p-6">
				<img src="{{entry.icon}}" alt="{{entry.name}}'s profile picture" class="w-24 h-24 rounded-full object-cover">
				<p class="text-center text-xl font-semibold tracking-tight">{{entry.name}}</p>
				<p class="text-center text-sm font-normal text-gray-500 leading-relaxed">{{entry.desc}}</p>
			</div>
		{% endfor %}
	</div>
</section>