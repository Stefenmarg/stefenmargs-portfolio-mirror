<footer class="pt-6 rounded-base shadow-xs">

  <div class="w-full flex flex-col items-center">

    <div class="flex flex-col sm:flex-row justify-center items-center sm:items-start gap-8 sm:gap-16 px-4 sm:px-0">
        <div class="max-w-xs text-center sm:text-left">
            <p class="text-center text-base text-gray-500 mb-8">About Us</p>
            <p class="text-sm text-gray-500 leading-relaxed">
                {{ footer.about }}
            </p>
        </div>
        <div class="flex-shrink-0 flex flex-col items-center sm:items-start">
            <p class="text-center text-base text-gray-500 mb-8">Contact Us</p>
            <div class="flex flex-col gap-2">
                {% for entry in contact.items %}
                <div class="flex items-center gap-2">
                    <i class="{{ entry.fa_icon }}"></i>
                    <span class="font-normal">{{ entry.value }}</span>
                </div>
                {% endfor %}
            </div>
        </div>
    </div>

    <hr class="my-4 border-default w-full lg:my-6" />

    <span class="block text-sm text-body sm:text-center pb-6">
      &copy; <span id="year"></span>
      <a href="/" class="hover:underline">{{ settings.title }}</a>
      All Rights Reserved.
    </span>

  </div>
</footer>