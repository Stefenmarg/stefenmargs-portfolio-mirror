---
layout: layouts/base.njk
---

<section class="relative px-10 max-w-3xl mx-auto">

	<div class="mb-8">
		<a href="/publications/" class="text-xs text-gray-400 hover:text-gray-600 transition-colors"><i class="fa-solid fa-angle-left"></i> Back to publications</a>
	</div>

	<!-- Header -->
	<div class="mb-10">
		{% if venue %}
			<span class="text-xs font-medium px-2 py-0.5 rounded-full bg-blue-100 border border-blue-400 text-blue-700 mb-4 inline-block">{{ venue }}</span>
		{% endif %}

		<h1 class="text-3xl md:text-5xl font-bold leading-tight mb-4">{{ title }}</h1>

		{% if authors %}
			<p class="text-sm text-gray-500 mb-3">
				{{ authors | join(", ") }}
			</p>
		{% endif %}

		<div class="flex items-center gap-4 text-xs text-gray-400">
			{% if date %}
				<span>
					{{ date |simplifyDate() }}
				</span>
			{% endif %}
		</div>
	</div>

	<div class="h-px bg-gray-200 mb-10"></div>

	<!-- Abstract / body -->
	<div class="prose prose-gray max-w-none text-gray-600 leading-relaxed">
		{{ content | safe }}
	</div>

	{% if url %}
		<div class="mt-10 pt-6 border-t border-gray-200">
			<a href="{{ url }}" target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2 text-sm font-medium text-gray-800 border border-gray-300 rounded-lg px-5 py-2.5 hover:border-gray-500 transition-colors">
				View full paper <i class="fa-solid fa-angle-right"></i>
			</a>
		</div>
	{% endif %}

</section>