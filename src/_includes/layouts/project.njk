---
layout: layouts/base.njk
---

<section class="relative px-10 max-w-3xl mx-auto">

	<div class="mb-8">
		<a href="/projects/" class="text-xs text-gray-400 hover:text-gray-600 transition-colors"> <i class="fa-solid fa-angle-left"></i> Back to projects </a>
	</div>

	<!-- Header -->
	<div class="mb-10">
		{% if category %}
			<span class="text-xs font-medium px-2 py-0.5 rounded-full bg-blue-100 border border-blue-400 text-blue-700 mb-4 inline-block">{{ category }}</span>
		{% endif %}

		<h1 class="text-3xl md:text-5xl font-bold leading-tight mb-4">{{ title }}</h1>

		{% if desc %}
			<p class="text-base text-gray-500 leading-relaxed mb-10">{{ desc }}</p>
		{% endif %}

		<div class="flex items-center gap-4 text-xs text-gray-400">
			{% if date %}
				<span>{{ date | simplifyDate() }}</span>
			{% endif %}

			{% if status %}
				{% if status == "Completed" %}
					<span class="px-2 py-0.5 rounded-full bg-green-200 text-green-700 border border-green-400">Completed</span>
				{% elseif status == "In progress" %}
					<span class="px-2 py-0.5 rounded-full bg-yellow-200 text-yellow-700 border border-yellow-400">In progress</span>
				{% endif %}
			{% endif %}
		</div>
	</div>

	<div class="h-px bg-gray-200 mb-10"></div>

	<!-- Body -->
	<div class="prose prose-gray max-w-none text-gray-600 leading-relaxed">
		{{ content | safe }}
	</div>

</section>